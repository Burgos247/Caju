# cajú — variables de entorno
# Copiar como .env.local para desarrollo, configurar en Vercel para producción

# ── Obligatorias en producción ────────────────────────────────────────────────

# URL base del deployment (sin trailing slash)
NEXT_PUBLIC_BASE_URL=https://caju.app

# ── Opcionales ────────────────────────────────────────────────────────────────

# Relays Nostr separados por coma
# Default si no se define: damus, nostr.band, nos.lol, snort.social
# NEXT_PUBLIC_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band

# ── v2: Zap pool via NWC ──────────────────────────────────────────────────────
# NEXT_PUBLIC_NWC_RELAY=wss://relay.getalby.com/v1
# NWC_SECRET=...

# ── v2: Relay dedicado ────────────────────────────────────────────────────────
# NEXT_PUBLIC_CAJU_RELAY=wss://relay.caju.app
